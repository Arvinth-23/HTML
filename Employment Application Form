<!DOCTYPE html>
<html>
<head>
    <title>Employment Application Form</title>
</head>
<body>
    <h2>Employment Application Form</h2>
    <form>
        <body bgcolor = red></body>
        <label>Full Name:</label><br>
        <input type="text" name="fullname"><br><br>
        <label>Email:</label><br>
        <input type="email" name="email"><br><br>
        <label>Phone Number:</label><br>
        <input type="tel" name="phone"><br><br>
        <label>Gender:</label><br>
        <input type="radio" name="gender" value="Male"> Male
        <input type="radio" name="gender" value="Female"> Female
        <br><br>
        <label>Date of Birth:</label><br>
        <input type="date" name="dob"><br><br>
        <label>Position Applying For:</label><br>
        <input type="text" name="position"><br><br>
        <label>Highest Qualification:</label><br>
        <select name="qualification">
            <option>Select</option>
            <option>High School</option>
            <option>Diploma</option>
            <option>Bachelor's Degree</option>
            <option>Master's Degree</option>
        </select><br><br>
        <label>Years of Experience:</label><br>
        <input type="number" name="experience"><br><br>
        <label>Skills:</label><br>
        <textarea name="skills" rows="4" cols="30"></textarea><br><br>
        <label>Upload Resume:</label><br>
        <input type="file" name="resume"><br><br>
        <input type="submit" value="Submit Application">
        <input type="reset" value="Clear">

    </form>

</body>
</html>
